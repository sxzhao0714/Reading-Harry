# 强制同步 Copilot 的对话数据
!/.obsidian/plugins/copilot-obsidian/*.json
!/.obsidian/plugins/copilot-obsidian/chats/

.obsidian/workspace.json

# 忽略 Copilot 的本地索引数据库
.copilot/
